{
  "config": {
    "MY_CALLSIGN": "AG6AQ",
    "MY_GRID": "CM97",
    "DX_CALLSIGN": "N6HAN",
    "DX_GRID": "CM87",
    "TX_ON_EVEN": true,
    "CQ_TYPE": "FD",
    "FREE_TEXT": "1A SCV"
  },
  "periods": [
    {
      "comment": "Period 0 (even): beacon starts — CQ FD",
      "beacon_change": { "time_offset": 1.0, "beacon_on": 1 }
    },
    {
      "comment": "Period 1 (odd): idle"
    },
    {
      "comment": "Period 2 (even): beacon CQ FD again"
    },
    {
      "comment": "Period 3 (odd): DX replies with FD exchange (TX2: '1B SCV') at SNR -5",
      "messages": [
        {
          "call_to": "${MY_CALLSIGN}",
          "call_from": "${DX_CALLSIGN}",
          "locator": "1B SCV",
          "snr": -5,
          "slot": 1
        }
      ]
    },
    {
      "comment": "Period 4 (even): we send R + our FD exchange (TX3)"
    },
    {
      "comment": "Period 5 (odd): DX sends RR73 at SNR -3",
      "messages": [
        {
          "call_to": "${MY_CALLSIGN}",
          "call_from": "${DX_CALLSIGN}",
          "locator": "RR73",
          "snr": -3,
          "slot": 1
        }
      ]
    },
    {
      "comment": "Period 6 (even): we send 73, QSO complete"
    }
  ],
  "expected_adif": [
    {
      "dxcall": "${DX_CALLSIGN}",
      "rst_sent": -5,
      "rst_rcvd": -5
    }
  ]
}
